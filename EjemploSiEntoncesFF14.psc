//Determinar si un nºmero ingresado por el usuairo es + o -
Algoritmo ejemploSiEntonces
	//Entrada
	Definir num Como Entero
	Escribir "Dame un nºmero entero: "
	Leer  num
	//Proceso 
	si (num>0) Entonces
		Escribir "Soy un nºmero POSITIVO"
	sino
		Escribir "Soy un nºmero NEGATIVO"
	FinSi
	//Salida
	
FinAlgoritmo
